local function updateESP(dt)
    espTimer += dt
    if espTimer < ESP_RATE then return end
    espTimer = 0
    local camPos = Camera.CFrame.Position
    for player, data in pairs(espPlayerData) do
        if not player or not player.Parent then removeESPForPlayer(player) continue end
        local character = player.Character
        if not character then continue end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChild("Humanoid")
        if not rootPart or not humanoid then continue end
        local dist = (rootPart.Position - camPos).Magnitude
        local alive = humanoid.Health > 0
        local show = dist <= espMaxDistance and alive
        if data.boxBillboard then data.boxBillboard.Enabled = show and espShowBoxes end
        if data.hpBillboard  then data.hpBillboard.Enabled  = show and espShowHealth  end
        if data.nameBillboard then data.nameBillboard.Enabled = show and espShowNames  end
        if data.distBillboard then data.distBillboard.Enabled = show and espShowDistance end
        if data.weaponBillboard then data.weaponBillboard.Enabled = show and espShowWeapon end
        if not show then continue end
        local hp = math.clamp(humanoid.Health/math.max(humanoid.MaxHealth,1),0,1)
        if data.hpFill then data.hpFill.Size = UDim2.new(1,0,math.max(0.02,hp),0); data.hpFill.BackgroundColor3 = Color3.new(1-hp,hp*0.9,0) end
        if data.hpText then data.hpText.Text = math.floor(humanoid.Health).."hp" end
        if data.boxStroke then data.boxStroke.Color = espColor end
        if data.nameLabel then data.nameLabel.TextColor3 = espColor end
        if data.distLabel then data.distLabel.Text = math.floor(dist).."m" end
        if data.weaponLabel and espShowWeapon then
            local tool = character:FindFirstChildOfClass("Tool")
            data.weaponLabel.Text = tool and ("["..tool.Name.."]") or "[no tool]"
        end
    end
end

local function clearAllESP()
    for player in pairs(espPlayerData) do removeESPForPlayer(player) end
    espPlayerData = {}
end

