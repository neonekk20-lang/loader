local fpsCounter, fpsTimer, fps = 0, 0, 0
local moduleTimer = 0

RunService.Heartbeat:Connect(function(dt)
    playerCacheTimer += dt
    if playerCacheTimer >= PLAYER_CACHE_RATE then
        playerCacheTimer = 0
        refreshPlayerCache()
    end
    if espEnabled then updateESP(dt) end
    fpsTimer += dt; fpsCounter += 1
    if fpsTimer >= 1 then fps = fpsCounter; fpsCounter = 0; fpsTimer = 0 end
    if watermarkFrame then
        local il = watermarkFrame:FindFirstChild("WMInfo")
        if il then
            local t = os.date("*t")
            il.Text = string.format("FPS: %d | %02d:%02d:%02d", fps, t.hour, t.min, t.sec)
        end
    end
    moduleTimer += dt
    if moduleTimer >= 0.3 then moduleTimer = 0; updateModuleList() end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if noclipEnabled then rebuildNoclipCache(); updateNoclip() end
    if speedEnabled then updateSpeed() end
    if flyEnabled then updateFly() end
    if jumpEnabled then updateJump() end
    if espEnabled then
        refreshPlayerCache()
        for _, p in ipairs(cachedPlayers) do createESPForPlayer(p) end
    end
    for _, player in ipairs(cachedPlayers) do createSilentPartForPlayer(player) end
end)

LocalPlayer.CharacterRemoving:Connect(function()
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    if flyGyro then flyGyro:Destroy(); flyGyro = nil end
    noclipCache = {}
end)

