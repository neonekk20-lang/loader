-- ==================== SILENT AIM PART ====================

local function createSilentPartForPlayer(player)
    if not player.Character then return end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if silentAimParts[player] and silentAimParts[player].Parent then
        silentAimParts[player]:Destroy()
    end
    local part = Instance.new("Part")
    part.Name = "Sakura_AimPoint"
    part.Size = Vector3.new(0.1, 0.1, 0.1)
    part.Anchored = false
    part.CanCollide = false
    part.Transparency = 1
    part.CastShadow = false
    part.Massless = true
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = root
    weld.Part1 = part
    weld.Parent = part
    part.CFrame = root.CFrame
    part.Parent = player.Character
    silentAimParts[player] = part
    return part
end

-- ==================== AIMBOT ====================

local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude

local function isVisible(targetPart)
    local char = LocalPlayer.Character
    if not char then return false end
    
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char}
    
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    local rayResult = workspace:Raycast(origin, direction.Unit * direction.Magnitude * 0.99, rayParams)
    
    if rayResult then
        local hit = rayResult.Instance
        local targetChar = targetPart.Parent
        if targetChar then
            return hit:IsDescendantOf(targetChar)
        end
        return false
    end
    return true
end

local function getAimPosition(player)
    local char = player.Character
    if not char then return nil end
    local spart = silentAimParts[player]
    if spart and spart.Parent then return spart.Position end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then return root.Position end
    return nil
end

local function getBestTarget()
    if #cachedPlayers == 0 then refreshPlayerCache() end
    local center = Vector2.new(Camera.ViewportSize.X*0.5, Camera.ViewportSize.Y*0.5)
    local camPos = Camera.CFrame.Position

    if aimbotLockOn and aimbotCurrentTarget then
        local char = aimbotCurrentTarget.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and root then
                local sp, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then return aimbotCurrentTarget end
            end
        end
        aimbotCurrentTarget = nil
    end

    local bestPlayer = nil
    local bestDist = aimbotFOV

    for _, player in ipairs(cachedPlayers) do
        local char = player.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        if aimbotTeamCheck then
            local mt = LocalPlayer.Team
            local pt = player.Team
            if mt and pt and mt == pt then continue end
        end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        if (root.Position - camPos).Magnitude > espMaxDistance then continue end
        local sp, onScreen = Camera:WorldToViewportPoint(root.Position)
        if not onScreen then continue end
        local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if screenDist > aimbotFOV then continue end
        if aimbotVisibleCheck and not isVisible(root) then continue end
        if screenDist < bestDist then
            bestDist = screenDist
            bestPlayer = player
        end
    end

    if bestPlayer and aimbotLockOn then aimbotCurrentTarget = bestPlayer end
    return bestPlayer
end

local function updateAimbot()
    if aimbotConnection then aimbotConnection:Disconnect(); aimbotConnection = nil end
    if not aimbotEnabled then
        if fovFrame then fovFrame.Visible = false end
        return
    end
    createFOVFrame()
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled then return end
        if aimbotShowFOV then updateFOVFrame() end
        if aimbotHoldKey and not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
        local targetPlayer = getBestTarget()
        if not targetPlayer then return end
        local targetPos = getAimPosition(targetPlayer)
        if not targetPos then return end
        if aimbotPrediction > 0 then
            local char = targetPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local vel = root.AssemblyLinearVelocity
                local dist = (targetPos - Camera.CFrame.Position).Magnitude
                targetPos = targetPos + vel * aimbotPrediction * math.clamp(dist/400, 0.05, 1)
            end
        end
        local sp = Camera:WorldToViewportPoint(targetPos)
        local center = Vector2.new(Camera.ViewportSize.X*0.5, Camera.ViewportSize.Y*0.5)
        local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        local smooth = math.clamp(aimbotSmoothing + screenDist/math.max(aimbotFOV,1)*0.2, aimbotSmoothing, 0.97)
        local cf = Camera.CFrame
        Camera.CFrame = cf:Lerp(CFrame.new(cf.Position, targetPos), 1 - smooth)
    end)
end

-- ==================== RAGEBOT ====================

local function updateRagebot()
    if ragebotConnection then ragebotConnection:Disconnect(); ragebotConnection = nil end
    if not ragebotEnabled then return end
    
    ragebotConnection = RunService.Heartbeat:Connect(function()
        if not ragebotEnabled then return end
        if #cachedPlayers == 0 then refreshPlayerCache() end
        
        local bestTarget = nil
        local bestDist = ragebotFOV
        local center = Vector2.new(Camera.ViewportSize.X*0.5, Camera.ViewportSize.Y*0.5)
        
        for _, player in ipairs(cachedPlayers) do
            if player == LocalPlayer then continue end
            local char = player.Character
            if not char then continue end
            local hum = char:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then continue end
            
            local head = char:FindFirstChild("Head")
            if not head then continue end
            
            local sp, onScreen = Camera:WorldToViewportPoint(head.Position)
            if not onScreen then continue end
            
            local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
            if screenDist > ragebotFOV then continue end
            if aimbotVisibleCheck and not isVisible(head) then continue end
            
            if screenDist < bestDist then
                bestDist = screenDist
                bestTarget = player
            end
        end
        
        if bestTarget then
            local char = bestTarget.Character
            if char then
                local head = char:FindFirstChild("Head")
                if head then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, head.Position)
                    
                    if ragebotAutoShoot then
                        local myChar = LocalPlayer.Character
                        local tool = myChar and myChar:FindFirstChildOfClass("Tool")
                        if tool then
                            pcall(function()
                                local remote = tool:FindFirstChild("Remote") or tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire")
                                if remote then
                                    if remote:IsA("RemoteEvent") then remote:FireServer()
                                    elseif remote:IsA("RemoteFunction") then remote:InvokeServer() end
                                else tool:Activate() end
                            end)
                        end
                    end
                end
            end
        end
    end)
end

-- ==================== TELEPORT ====================

local function getClosestEnemyCharacter()
    if #cachedPlayers == 0 then refreshPlayerCache() end
    local closest, closestDist = nil, math.huge
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    for _, player in ipairs(cachedPlayers) do
        local char = player.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        if aimbotTeamCheck and player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local dist = (root.Position - myRoot.Position).Magnitude
        if dist < closestDist then closestDist = dist; closest = char end
    end
    return closest
end

local function teleportToOpponent()
    local char = getClosestEnemyCharacter()
    if not char then notify("No enemy found!", 1.5) return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    myRoot.CFrame = root.CFrame + Vector3.new(teleportOffset, 0, 0)
    notify("Teleported to " .. (char.Parent and char.Parent.Name or "?"), 1.5)
end

local function updateContinuousTeleport()
    if teleportConnection then teleportConnection:Disconnect(); teleportConnection = nil end
    if not teleportEnabled then return end
    teleportConnection = RunService.Heartbeat:Connect(function()
        if not teleportEnabled then return end
        local char = getClosestEnemyCharacter()
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        if (myRoot.Position - root.Position).Magnitude > teleportOffset + 2 then
            myRoot.CFrame = root.CFrame + Vector3.new(teleportOffset, 0, 0)
        end
    end)
end

-- ==================== AUTO KNIFE ====================

local function doAutoKnife()
    local char = getClosestEnemyCharacter()
    if not char then return end
    local enemyRoot = char:FindFirstChild("HumanoidRootPart")
    if not enemyRoot then return end
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    myRoot.CFrame = enemyRoot.CFrame * CFrame.new(0, 0, 2.5)
    task.wait(0.08)
    local tool = myChar:FindFirstChildOfClass("Tool")
    if tool then
        pcall(function()
            local remote = tool:FindFirstChild("Remote") or tool:FindFirstChild("Slash") or tool:FindFirstChild("Attack") or tool:FindFirstChild("Fire")
            if remote and remote:IsA("RemoteEvent") then remote:FireServer()
            else tool:Activate() end
        end)
    end
end

local function updateAutoKnife()
    if autoKnifeConnection then autoKnifeConnection:Disconnect(); autoKnifeConnection = nil end
    if not autoKnifeEnabled then return end
    autoKnifeConnection = RunService.Heartbeat:Connect(function()
        if not autoKnifeEnabled then return end
        local char = getClosestEnemyCharacter()
        if not char then return end
        local er = char:FindFirstChild("HumanoidRootPart")
        if not er then return end
        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        if (myRoot.Position - er.Position).Magnitude <= autoKnifeRange then
            doAutoKnife()
            task.wait(autoKnifeDelay)
        end
    end)
end

-- ==================== AUTO SHOOT ====================

local function updateAutoShoot()
    if autoShootConnection then autoShootConnection:Disconnect() end
    if not autoShootEnabled then return end
    autoShootConnection = RunService.Heartbeat:Connect(function()
        if not autoShootEnabled then return end
        local character = LocalPlayer.Character
        if not character then return end
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            local remote = tool:FindFirstChild("Remote") or tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire")
            if remote then
                pcall(function()
                    if remote:IsA("RemoteEvent") then remote:FireServer()
                    elseif remote:IsA("RemoteFunction") then remote:InvokeServer() end
                end)
            else pcall(function() tool:Activate() end) end
        end
        task.wait(math.max(0.05, autoShootDelay))
    end)
end

