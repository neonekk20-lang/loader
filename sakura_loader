local function removeESPForPlayer(player)
    local data = espPlayerData[player]
    if not data then return end
    for _, key in ipairs({"boxBillboard","hpBillboard","nameBillboard","distBillboard","weaponBillboard"}) do
        local obj = data[key]
        if obj and obj.Parent then obj:Destroy() end
    end
    if silentAimParts[player] and silentAimParts[player].Parent then
        silentAimParts[player]:Destroy()
    end
    silentAimParts[player] = nil
    espPlayerData[player] = nil
end

