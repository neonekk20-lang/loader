function updateTabVisibility()
    if not tabContents then return end
    for _, tabName in ipairs({"Combat", "Ragebot", "Visuals", "Misc", "Settings"}) do
        local tc = tabContents[tabName]
        if tc then
            local active = (tabName == currentTab)
            tc.left.Visible = active
            tc.right.Visible = active
        end
    end
end

-- ==================== KEYBINDS ====================

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F1 or input.KeyCode == Enum.KeyCode.RightShift then
        if mainFrame then
            guiVisible = not guiVisible
            mainFrame.Visible = guiVisible
        end
    elseif input.KeyCode == Enum.KeyCode.G then
        aimbotEnabled = not aimbotEnabled; updateAimbot()
        notify("Aimbot "..(aimbotEnabled and "ON" or "OFF"), 1.5)
    elseif input.KeyCode == Enum.KeyCode.R then
        ragebotEnabled = not ragebotEnabled; updateRagebot()
        notify("Ragebot "..(ragebotEnabled and "ON" or "OFF"), 1.5)
    elseif input.KeyCode == Enum.KeyCode.X then
        espEnabled = not espEnabled
        if espEnabled then refreshPlayerCache(); for _,p in ipairs(cachedPlayers) do createESPForPlayer(p) end
        else clearAllESP() end
        notify("ESP "..(espEnabled and "ON" or "OFF"), 1.5)
    elseif input.KeyCode == Enum.KeyCode.H then
        speedEnabled = not speedEnabled; updateSpeed()
        notify("Speed "..(speedEnabled and "ON" or "OFF"), 1.5)
    elseif input.KeyCode == Enum.KeyCode.J then
        flyEnabled = not flyEnabled; updateFly()
        notify("Fly "..(flyEnabled and "ON" or "OFF"), 1.5)
    elseif input.KeyCode == Enum.KeyCode.K then
        noclipEnabled = not noclipEnabled; updateNoclip()
        notify("NoClip "..(noclipEnabled and "ON" or "OFF"), 1.5)
    elseif input.KeyCode == Enum.KeyCode.T then
        teleportToOpponent()
    elseif input.KeyCode == Enum.KeyCode.N then
        autoKnifeEnabled = not autoKnifeEnabled; updateAutoKnife()
        notify("Auto Knife "..(autoKnifeEnabled and "ON" or "OFF"), 1.5)
    end
end)

